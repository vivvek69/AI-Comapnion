# Force LF line endings for all shell scripts — they run on Linux/Pi
# and will fail with "bad interpreter" if saved with CRLF.
*.sh        text eol=lf
*.bash      text eol=lf

# Windows batch files must keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Python and text files: normalize to LF
*.py        text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf

# Binary files — no line ending conversion
*.npy       binary
*.task      binary
